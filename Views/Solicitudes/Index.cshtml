@model PlataformaCredito.ViewModels.SolicitudFiltroViewModel
@{
    ViewData["Title"] = "Mis Solicitudes";
}

<h2>Mis Solicitudes</h2>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@* Filtros *@
<form method="get" asp-action="Index" class="mb-4 p-3 border rounded bg-light">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label">Estado</label>
            <select name="Estado" class="form-select form-select-sm">
                <option value="">Todos</option>
                @foreach (var e in Enum.GetValues<PlataformaCredito.Models.EstadoSolicitud>())
                {
                    <option value="@e" selected="@(Model.Estado == e)">@e</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Monto mín.</label>
            <input type="number" name="MontoMin" value="@Model.MontoMin" class="form-control form-control-sm" min="0" step="100" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Monto máx.</label>
            <input type="number" name="MontoMax" value="@Model.MontoMax" class="form-control form-control-sm" min="0" step="100" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Fecha inicio</label>
            <input type="date" name="FechaInicio" value="@Model.FechaInicio?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Fecha fin</label>
            <input type="date" name="FechaFin" value="@Model.FechaFin?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm w-100">Filtrar</button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">Limpiar</a>
        </div>
    </div>
</form>

@* Error de validación server-side *@
@if (Model.ErrorFiltro != null)
{
    <div class="alert alert-danger">@Model.ErrorFiltro</div>
}

@* Tabla de resultados *@
@if (!Model.Solicitudes.Any())
{
    <p class="text-muted">No se encontraron solicitudes.</p>
}
else
{
    <table class="table table-hover table-bordered">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Monto solicitado</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Solicitudes)
            {
                <tr>
                    <td>@s.Id</td>
                    <td>@s.MontoSolicitado.ToString("C")</td>
                    <td>@s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td>
                        <span class="badge @(s.Estado == PlataformaCredito.Models.EstadoSolicitud.Pendiente ? "bg-warning text-dark" :
                                             s.Estado == PlataformaCredito.Models.EstadoSolicitud.Aprobado  ? "bg-success" : "bg-danger")">
                            @s.Estado
                        </span>
                    </td>
                    <td>
                        <a asp-action="Detalle" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Ver detalle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
