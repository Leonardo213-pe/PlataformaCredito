@using Microsoft.AspNetCore.Identity
@using PlataformaCredito.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="pc-nav-link" asp-area="Identity" asp-page="/Account/Manage/Index">
            @User.Identity?.Name
        </a>
    </li>
    <li class="nav-item">
        <form asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
              method="post" style="margin:0;">
            <button type="submit" class="pc-nav-link" style="background:none;border:none;cursor:pointer;">
                Salir
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="pc-nav-link" asp-area="Identity" asp-page="/Account/Register">Registrarse</a>
    </li>
    <li class="nav-item">
        <a class="pc-nav-link" asp-area="Identity" asp-page="/Account/Login">Iniciar sesión</a>
    </li>
}
