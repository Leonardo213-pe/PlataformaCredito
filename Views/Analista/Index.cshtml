@model List<PlataformaCredito.Models.SolicitudCredito>
@{
    ViewData["Title"] = "Panel Analista";
}

<div class="pc-page-header">
    <div>
        <h1 class="pc-page-title">Panel de Analista</h1>
        <p class="pc-page-sub">Solicitudes pendientes de evaluación — @Model.Count en cola</p>
    </div>
</div>

@if (TempData["Exito"] != null)
{
    <div class="pc-alert pc-alert-success">✓ @TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="pc-alert pc-alert-danger">✕ @TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="pc-empty">
        <div class="pc-empty-icon">✅</div>
        <p>No hay solicitudes pendientes.</p>
    </div>
}
else
{
    <div class="pc-table-wrap">
        <table class="pc-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Cliente</th>
                    <th>Ingresos</th>
                    <th>Monto</th>
                    <th>Límite (5×)</th>
                    <th>Fecha</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    var limite = s.Cliente!.IngresosMensuales * 5;
                    var excede = s.MontoSolicitado > limite;
                    <tr class="@(excede ? "row-warning" : "")">
                        <td class="pc-muted">@s.Id</td>
                        <td>@(s.Cliente?.Usuario?.Email ?? "—")</td>
                        <td>@s.Cliente!.IngresosMensuales.ToString("C")</td>
                        <td><strong>@s.MontoSolicitado.ToString("C")</strong></td>
                        <td>
                            @limite.ToString("C")
                            @if (excede)
                            {
                                <span class="pc-badge pc-badge-rechazado ms-1" style="font-size:0.7rem;">Excede</span>
                            }
                        </td>
                        <td class="pc-muted">@s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="d-flex gap-2">
                                @if (!excede)
                                {
                                    <form asp-action="Aprobar" asp-route-id="@s.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-pc btn-pc-success" style="padding:0.35rem 0.9rem;font-size:0.8rem;">
                                            Aprobar
                                        </button>
                                    </form>
                                }
                                <a asp-action="Rechazar" asp-route-id="@s.Id" class="btn-pc btn-pc-danger" style="padding:0.35rem 0.9rem;font-size:0.8rem;">
                                    Rechazar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
